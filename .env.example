SITE_HOST=localhost
WEB_COMMAND=python manage.py runserver 0.0.0.0:8000
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_CSRF_TRUSTED_ORIGINS=https://localhost,https://127.0.0.1
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_DATABASE=postgres
POSTGRES_DB=legit_dashboard
POSTGRES_USER=legit
POSTGRES_PASSWORD=legit
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DJANGO_CREATE_SUPERUSER=1
DJANGO_SUPERUSER_USERNAME=admin@example.com
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=change-me
