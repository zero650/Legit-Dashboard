SITE_HOST=dashboard.jamesonbates.net
WEB_COMMAND=gunicorn legit_dashboard.wsgi:application --bind 0.0.0.0:8000 --workers 3
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=dashboard.jamesonbates.net
DJANGO_CSRF_TRUSTED_ORIGINS=https://dashboard.jamesonbates.net
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=False
DJANGO_SECURE_HSTS_PRELOAD=False
DJANGO_SECURE_REFERRER_POLICY=same-origin
DJANGO_DATABASE=postgres
POSTGRES_DB=legit_dashboard
POSTGRES_USER=legit
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
DJANGO_CREATE_SUPERUSER=0
